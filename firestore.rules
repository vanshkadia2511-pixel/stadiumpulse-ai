rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Zones collection
    match /zones/{zoneId} {
      // Allow read access to any authenticated user (including anonymous)
      allow read: if request.auth != null;
      
      // Allow write access only if the data structure is valid
      // In a real production app, you would limit this to specific staff roles
      allow write: if request.auth != null 
        && request.resource.data.keys().hasAll(['name', 'current_occupancy_percentage', 'capacity', 'wait_time_minutes']);
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
